# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment / secrets
.env
*.env
config/api_keys.php
# Uncomment this if your database.php contains real passwords
# config/database.php

# Logs / cache
*.log
logs/
cache/
tmp/
temp/

# PHP dependencies installed by Composer
vendor/

# User uploaded files / private reports
uploads/*
!uploads/.gitkeep
assets/uploads/*
!assets/uploads/.gitkeep

# Python cache, just in case
__pycache__/
*.pyc

# Node/Tailwind build dependencies, if added later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*